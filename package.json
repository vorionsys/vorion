{
  "name": "@vorion/platform",
  "version": "0.1.0",
  "description": "Vorion - Governed AI Execution Platform",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vorion": "./dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vorion/vorion.git"
  },
  "author": "Vorion, Inc.",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run copy-swagger-assets && tsc && tsc-alias",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "vitest run --dir tests/e2e",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint packages apps",
    "lint:fix": "eslint packages apps --fix",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist coverage",
    "verify-setup": "tsx scripts/verify-setup.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "tsx scripts/seed.ts",
    "docs:api": "typedoc --out docs/api src/index.ts",
    "copy-swagger-assets": "mkdir -p public/swagger && cp node_modules/swagger-ui-dist/swagger-ui.css public/swagger/ && cp node_modules/swagger-ui-dist/swagger-ui-bundle.js public/swagger/ && cp node_modules/swagger-ui-dist/swagger-ui-standalone-preset.js public/swagger/",
    "generate-swagger-sri": "tsx scripts/generate-swagger-sri.ts",
    "security:audit": "npm audit --audit-level=high",
    "check:circular": "madge --circular --extensions ts,tsx packages/"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.978.0",
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/client-ses": "^3.978.0",
    "@aws-sdk/client-sns": "^3.978.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@simplewebauthn/server": "^13.2.2",
    "ajv": "^8.12.0",
    "argon2": "^0.44.0",
    "bullmq": "^4.12.2",
    "commander": "^11.1.0",
    "dayjs": "^1.11.10",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.7.3",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.3.2",
    "jsonpath-plus": "^10.3.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.4",
    "node-cron": "^4.2.1",
    "nodemailer": "8.0.0",
    "openid-client": "^6.8.1",
    "otplib": "^13.2.1",
    "pg": "^8.11.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "swagger-ui-dist": "^5.31.0",
    "uuid": "^11.0.0",
    "zod": "^3.22.4",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/zxcvbn": "^4.4.5",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.5.3",
    "happy-dom": "^20.7.0",
    "https-proxy-agent": "^5.0.0",
    "jsdom": "^28.1.0",
    "madge": "^7.0.0",
    "node-fetch": "^2.6.7",
    "openapi-types": "^12.1.3",
    "path-to-regexp": "^6.3.0",
    "prettier": "^3.2.4",
    "progress": "^2.0.3",
    "proxy-from-env": "^1.1.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typedoc": "^0.25.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18",
    "which": "^2.0.2"
  },
  "overrides": {
    "wrangler": "^4.63.0",
    "axios": ">=1.13.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "drizzle-orm": "^0.44.7",
    "qs": "6.15.0",
    "bn.js": ">=5.2.3",
    "lodash": ">=4.17.23",
    "fast-xml-parser": ">=5.3.8",
    "path-to-regexp": "$path-to-regexp",
    "eslint": {
      "minimatch": "3.1.4",
      "ajv": "6.14.0"
    },
    "@storybook/nextjs": {
      "minimatch": "3.1.4",
      "ajv": "6.14.0"
    },
    "@sentry/nextjs": {
      "minimatch": "9.0.7"
    },
    "@sentry/node": {
      "minimatch": "9.0.7"
    },
    "glob": {
      "minimatch": "10.2.3"
    },
    "@stryker-mutator/core": {
      "minimatch": "10.2.3",
      "ajv": "8.18.0"
    }
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5"
    }
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples"
  ]
}
