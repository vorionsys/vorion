%%{init: {'theme': 'dark'}}%%
graph LR
    subgraph TRUST["Trust Data Pipeline"]
        TE["Trust Engine<br/>(atsf-core)"]
        TD["Trust Dynamics<br/>(a3i)"]
        TE --> TD
    end

    subgraph APIS["API Layer"]
        CG["Cognigate API<br/>cognigate.dev"]
        AA_API["AgentAnchor API<br/>29 routes"]
        INT_API["Internal API<br/>Fastify"]
    end

    subgraph FRONTEND["Frontend Apps"]
        AA["AgentAnchor Portal<br/>73 pages"]
        AU["Aurais Portal<br/>24 pages"]
        KZ["Kaizen Learning<br/>15 pages"]
        VA["Vorion Admin<br/>10 pages"]
    end

    subgraph OPS["Operations"]
        BAI["BAI-CC Dashboard<br/>6 pages"]
        KV["Cloudflare KV<br/>7 keys"]
        ST["Status Page"]
    end

    subgraph DOCS["Documentation"]
        BD["BASIS Docs<br/>basis.vorion.org"]
        AD["ACI Docs<br/>aci.vorion.org"]
    end

    subgraph MKT["Marketing Sites"]
        MK["Vorion Marketing<br/>vorion.org"]
        AW["AgentAnchor WWW<br/>agentanchorai.com"]
        BW["BAI-CC WWW<br/>bai-cc.com"]
        AUR["Aurais WWW<br/>aurais.net"]
    end

    %% Core data flows
    TE -->|"trust scores"| CG
    TD -->|"dynamics"| CG
    CG -->|"REST API"| AA
    CG -->|"REST API"| AU
    AA_API -->|"agent data"| AA
    AA_API -->|"health checks"| ST
    AA_API -->|"metrics"| BAI
    INT_API -->|"agent commands"| VA
    BAI -->|"read/write"| KV
    KV -->|"cached metrics"| BAI

    %% Knowledge flows
    BD -.->|"standard reference"| AA
    AD -.->|"identity spec"| CG
    KZ -.->|"curriculum feeds"| AA

    %% Marketing funnels
    MK -.->|"links to"| AW
    MK -.->|"links to"| BD
    AW -.->|"leads to"| AA
    BW -.->|"links to"| BAI

    %% Styles
    style BAI fill:#ff6b6b,stroke:#c92a2a,color:#fff
    style CG fill:#ffa94d,stroke:#e67700,color:#000
    style TE fill:#51cf66,stroke:#2b8a3e,color:#000
    style TD fill:#51cf66,stroke:#2b8a3e,color:#000
