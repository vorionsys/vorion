# =============================================================================
# Vorion Air-Gap Environment Configuration
# =============================================================================
#
# IMPORTANT SECURITY NOTES:
# 1. Copy this file to .env and configure ALL values before deployment
# 2. Generate strong, unique passwords for all services
# 3. NEVER commit the .env file to version control
# 4. Restrict file permissions: chmod 600 .env
# 5. Back up this file securely - losing it may require reinstallation
#
# Password Generation Commands:
#   Strong password: openssl rand -base64 32
#   JWT secret:      openssl rand -base64 64
#
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL superuser credentials
# Used for database administration and application access
POSTGRES_USER=vorion
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_1
POSTGRES_DB=vorion

# =============================================================================
# Cache Configuration
# =============================================================================

# Redis authentication password
# Used for session storage and caching
REDIS_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_2

# =============================================================================
# Application Security
# =============================================================================

# JSON Web Token signing secret
# CRITICAL: Must be at least 64 characters for security
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_WITH_64_CHAR_OR_LONGER_SECRET_KEY_GENERATED_SECURELY

# Session encryption secret
# Used for encrypting session data
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_THIS_WITH_32_CHAR_SECRET_KEY

# Cookie signing key (optional, defaults to SESSION_SECRET)
# COOKIE_SECRET=

# =============================================================================
# Network Configuration
# =============================================================================

# External HTTP port (redirect to HTTPS)
HTTP_PORT=80

# External HTTPS port (main application access)
HTTPS_PORT=443

# Allowed CORS origins
# In air-gapped environment, this should match your internal hostname
CORS_ORIGIN=https://vorion.local

# Internal hostname for service communication
# Update /etc/hosts on all client machines to resolve this
INTERNAL_HOSTNAME=vorion.local

# =============================================================================
# TLS/SSL Configuration
# =============================================================================

# Paths to SSL certificates (relative to installation directory)
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key
SSL_CA_PATH=./certs/ca.crt

# TLS minimum version (1.2 or 1.3)
TLS_MIN_VERSION=1.2

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# Log retention (days)
LOG_RETENTION_DAYS=90

# =============================================================================
# License Configuration
# =============================================================================

# Path to license file
LICENSE_FILE_PATH=./license.key

# =============================================================================
# Backup Configuration
# =============================================================================

# Backup storage location
BACKUP_PATH=/var/backups/vorion

# Number of days to retain backups
BACKUP_RETENTION_DAYS=30

# Enable automatic daily backups (true/false)
AUTO_BACKUP_ENABLED=true

# Backup time (24-hour format, server local time)
AUTO_BACKUP_TIME=02:00

# =============================================================================
# Resource Limits
# =============================================================================

# Maximum upload file size (in MB)
MAX_UPLOAD_SIZE=100

# Session timeout (in seconds)
SESSION_TIMEOUT=3600

# Maximum concurrent connections per user
MAX_CONNECTIONS_PER_USER=5

# =============================================================================
# Air-Gap Specific Settings
# =============================================================================

# Disable all telemetry and analytics
DISABLE_TELEMETRY=true

# Disable automatic update checks
DISABLE_UPDATE_CHECK=true

# Disable external integrations (OAuth, webhooks to external URLs)
DISABLE_EXTERNAL_INTEGRATIONS=true

# Enable offline mode (disables features requiring internet)
OFFLINE_MODE=true

# Internal NTP server (optional, for time synchronization)
# If not set, system time must be manually synchronized
# NTP_SERVER=ntp.internal.local

# Internal DNS server (optional)
# DNS_SERVER=dns.internal.local

# =============================================================================
# Optional Services
# =============================================================================

# MinIO Object Storage (if enabled in docker-compose)
# MINIO_ROOT_USER=admin
# MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD

# Grafana (if enabled)
# GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# =============================================================================
# Advanced Configuration
# =============================================================================

# Node.js runtime options
# NODE_OPTIONS=--max-old-space-size=4096

# Database connection pool size
# DB_POOL_SIZE=20

# Redis connection pool size
# REDIS_POOL_SIZE=10

# =============================================================================
# End of Configuration
# =============================================================================
