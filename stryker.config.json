{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/api/schema/stryker-core.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress", "json"],
  "mutate": [
    "packages/contracts/src/**/*.ts",
    "!packages/contracts/src/**/*.test.ts",
    "!packages/contracts/src/**/index.ts",
    "packages/platform-core/src/common/**/*.ts",
    "!packages/platform-core/src/common/**/*.test.ts",
    "packages/security/src/security/service-auth/**/*.ts",
    "!packages/security/src/security/service-auth/**/*.test.ts",
    "!packages/security/src/security/service-auth/**/__tests__/**",
    "packages/security/src/security/webauthn/**/*.ts",
    "!packages/security/src/security/webauthn/**/*.test.ts",
    "!packages/security/src/security/webauthn/**/__tests__/**",
    "packages/security/src/security/mfa/**/*.ts",
    "!packages/security/src/security/mfa/**/*.test.ts",
    "!packages/security/src/security/mfa/**/__tests__/**",
    "packages/security/src/security/incident/executor.ts",
    "packages/security/src/security/incident/triggers.ts",
    "packages/security/src/security/policy-engine/**/*.ts",
    "!packages/security/src/security/policy-engine/**/*.test.ts",
    "!packages/security/src/security/policy-engine/**/__tests__/**"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "timeoutFactor": 2.5,
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 75
  },
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    ".next",
    "k6",
    "e2e",
    ".stryker-tmp"
  ]
}
