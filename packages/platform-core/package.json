  "description": "Core business logic for Vorion platform - trust engine, governance, enforcement, and proof systems",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./trust-engine": {
      "types": "./dist/trust-engine/index.d.ts",
      "import": "./dist/trust-engine/index.js"
    },
