    },
    "./db/client": {
      "types": "./dist/db/client.d.ts",
      "import": "./dist/db/client.js"
    },
    "./car-extensions": {
      "types": "./dist/car-extensions/index.d.ts",
      "import": "./dist/car-extensions/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
