{
  "name": "@vorionsys/agentanchor-sdk",
  "version": "0.1.0",
  "description": "Official SDK for Agent Anchor - AI agent registry, trust scoring, and attestations",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./car": {
      "types": "./dist/car/index.d.ts",
      "import": "./dist/car/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vorionsys/shared-constants": "^1.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voriongit/vorion.git",
    "directory": "packages/agentanchor-sdk"
  },
  "homepage": "https://agentanchorai.com",
  "bugs": {
    "url": "https://github.com/voriongit/vorion/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "trust",
    "governance",
    "aci",
    "attestation",
    "sdk",
    "agentanchor"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
