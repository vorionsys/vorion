{
  "name": "@vorionsys/car-cli",
  "version": "1.0.0",
  "description": "CLI for CAR (Categorical Agentic Registry) agent identity and governance operations",
  "type": "module",
  "bin": {
    "car": "dist/cli.js"
  },
  "main": "./dist/index.js",
