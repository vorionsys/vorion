{
  "name": "@vorionsys/sdk",
  "version": "0.1.2",
  "description": "Vorion SDK - Simple interface for AI agent governance",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pino": "^9.0.0"
  },
  "peerDependencies": {
    "@vorionsys/runtime": ">=0.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@vorionsys/runtime": {
      "optional": false
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vorionsys/runtime": "^0.1.1",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/__tests__",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "author": "Vorion <team@vorion.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/vorion.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/vorion/issues"
  },
  "homepage": "https://github.com/vorionsys/vorion/tree/main/packages/sdk#readme",
  "keywords": [
    "ai",
    "agent",
    "governance",
    "trust",
    "sdk",
    "vorion",
    "basis",
    "safety",
    "interoperability"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
