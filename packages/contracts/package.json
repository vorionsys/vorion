{
  "name": "@vorionsys/contracts",
  "version": "0.1.2",
  "description": "Shared schemas, Zod validators, and TypeScript types for the Vorion AI governance platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "import": "./dist/common/index.js",
      "require": "./dist/common/index.js"
    },
    "./common/*": {
      "types": "./dist/common/*.d.ts",
      "import": "./dist/common/*.js",
      "require": "./dist/common/*.js"
    },
    "./v2": {
      "types": "./dist/v2/index.d.ts",
      "import": "./dist/v2/index.js",
      "require": "./dist/v2/index.js"
    },
    "./v2/*": {
      "types": "./dist/v2/*.d.ts",
      "import": "./dist/v2/*.js",
      "require": "./dist/v2/*.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js",
      "require": "./dist/validators/index.js"
    },
    "./validators/*": {
      "types": "./dist/validators/*.d.ts",
      "import": "./dist/validators/*.js",
      "require": "./dist/validators/*.js"
    },
    "./aci": {
      "types": "./dist/aci/index.d.ts",
      "import": "./dist/aci/index.js",
      "require": "./dist/aci/index.js"
    },
    "./canonical": {
      "types": "./dist/canonical/index.d.ts",
      "import": "./dist/canonical/index.js",
      "require": "./dist/canonical/index.js"
    },
    "./canonical/*": {
      "types": "./dist/canonical/*.d.ts",
      "import": "./dist/canonical/*.js",
      "require": "./dist/canonical/*.js"
    },
    "./canonical/governance": {
      "types": "./dist/canonical/governance.d.ts",
      "import": "./dist/canonical/governance.js",
      "require": "./dist/canonical/governance.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "require": "./dist/db/index.js"
    },
    "./car": {
      "types": "./dist/car/index.d.ts",
      "import": "./dist/car/index.js",
      "require": "./dist/car/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "vorion",
    "contracts",
    "schemas",
    "validators",
    "zod",
    "typescript",
    "trust",
    "governance",
    "ai-safety",
    "agent",
    "ai-agent",
    "proof",
    "audit-trail",
    "policy"
  ],
  "author": "Vorion <team@vorion.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/vorion.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://vorion.org",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
