{
  "name": "@vorionsys/n8n-nodes-cognigate",
  "version": "0.1.0",
  "description": "n8n community node for Cognigate — AI agent trust scoring, capability enforcement, and audit proof via the BASIS standard",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "cognigate",
    "vorion",
    "ai-governance",
    "trust-scoring",
    "basis",
    "ai-agent"
  ],
  "license": "Apache-2.0",
  "homepage": "https://cognigate.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vorionsys/vorion.git"
  },
  "author": {
    "name": "Vorion",
    "email": "hello@vorion.org"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp nodes/Cognigate/cognigate.svg dist/nodes/Cognigate/cognigate.svg",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts"
  },
  "files": [
    "dist",
    "nodes",
    "credentials",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CognigateApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Cognigate/Cognigate.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
