{
  "name": "@vorionsys/proof-plane",
  "version": "0.1.2",
  "description": "Immutable dual-hash audit trail for AI agent governance decisions (SHA-256 + SHA3-256 chain, Ed25519 signatures)",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./proof-plane": {
      "types": "./dist/proof-plane/index.d.ts",
      "import": "./dist/proof-plane/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "openapi.yaml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vorionsys/contracts": "^0.1.1",
    "uuid": "^11.0.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "vorion",
    "basis",
    "proof-plane",
    "audit-trail",
    "hash-chain",
    "dual-hash",
    "sha256",
    "sha3",
    "ed25519",
    "immutable",
    "tamper-detection",
    "cryptographic",
    "ai",
    "agent",
    "governance",
    "compliance"
  ],
  "author": "Vorion <team@vorion.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/vorion.git",
    "directory": "packages/proof-plane"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/vorion/issues"
  },
  "homepage": "https://vorion.org",
  "engines": {
    "node": ">=18.0.0"
  }
}
