{
  "name": "@vorion/security",
  "version": "1.0.0",
  "description": "Enterprise security modules for Vorion platform - WebAuthn, MFA, SIEM, ZKP, HSM, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
