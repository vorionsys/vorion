{
  "name": "@vorionsys/cognigate",
  "version": "1.0.2",
  "description": "Real-time AI governance decision engine -- TypeScript SDK for the Cognigate API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proof-bridge": {
      "types": "./dist/proof-bridge.d.ts",
      "import": "./dist/proof-bridge.js",
      "require": "./dist/proof-bridge.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/proof-bridge.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "keywords": [
    "ai",
    "governance",
    "trust",
    "agents",
    "cognigate",
    "basis",
    "vorion",
    "ai-safety",
    "trust-tiers",
    "proof-chain",
    "audit-trail",
    "policy-enforcement"
  ],
  "author": "Vorion <team@vorion.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/vorion.git",
    "directory": "packages/cognigate"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/vorion/issues"
  },
  "homepage": "https://cognigate.dev",
  "dependencies": {
    "@vorionsys/shared-constants": "^1.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
