# Dependencies — installed inside the container
node_modules

# Build artifacts — rebuilt inside the container
dist
coverage

# Turbo cache
.turbo

# Source control
.git
.gitignore

# IDE / editor
.vscode
.idea
*.swp
*.swo

# Environment files (secrets must never be baked into images)
.env
.env.*

# Docker files (avoid recursive COPY)
Dockerfile
docker-compose*.yml
.dockerignore

# Tests and config not needed at runtime
tests
vitest.config.ts
tsconfig.json

# Deployment configs for other platforms
fly.toml
railway.json
