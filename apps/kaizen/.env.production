# Supabase config is set via Vercel/hosting environment variables:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Vorion Platform API (routes AI calls through vorionsys-api on Fly.io)
# PLATFORM_API_URL=https://vorionsys-api.fly.dev
# PLATFORM_API_KEY=<set in Vercel dashboard — do not commit>
