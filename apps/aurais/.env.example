# ============================================
# Aurais Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# OAuth (GitHub, Google) is handled via Supabase dashboard — no app-level OAuth vars needed.

# Supabase (required — app will not start without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL (used for auth redirects)
NEXT_PUBLIC_URL=https://aurais.net

# Cognigate API (agent governance — optional, defaults shown)
COGNIGATE_API_URL=https://cognigate.dev
COGNIGATE_API_KEY=
