---
import BaseLayout from '../../layouts/BaseLayout.astro';

const trustLevels = [
  { tier: 0, name: 'Sandbox', score: '0-199', factors: 0, description: 'New agents start here. Observation only, extremely limited capabilities.', capabilities: ['Read public data', 'Generate responses', 'Observe system state'] },
  { tier: 1, name: 'Observed', score: '200-349', factors: 3, description: 'Basic competence demonstrated through Competence, Reliability, and Observability factors.', capabilities: ['Basic file operations', 'Supervised external calls', 'Full logging required'] },
  { tier: 2, name: 'Provisional', score: '350-499', factors: 6, description: 'Accountability and safety emerging. Adds Transparency, Safety, and Accountability factors.', capabilities: ['Standard operations', 'External API access', 'Self-reporting'] },
  { tier: 3, name: 'Verified', score: '500-649', factors: 9, description: 'Security and identity confirmed. Adds Privacy, Security, and Alignment factors.', capabilities: ['Cross-agent communication', 'Extended operations', 'Reduced oversight'] },
  { tier: 4, name: 'Operational', score: '650-799', factors: 12, description: 'Human oversight and alignment proven. Adds Oversight, Consent, and Explainability factors.', capabilities: ['Administrative tasks', 'Resource management', 'Policy reading'] },
  { tier: 5, name: 'Trusted', score: '800-875', factors: 14, description: 'Stewardship and humility demonstrated. Adds Humility and Stewardship factors.', capabilities: ['Agent delegation', 'Advanced operations', 'Audit access'] },
  { tier: 6, name: 'Certified', score: '876-949', factors: 15, description: 'Adaptability and causal reasoning. Adds Learning factor (all 15 core factors).', capabilities: ['System administration', 'Policy modification', 'Emergency response'] },
  { tier: 7, name: 'Autonomous', score: '950-1000', factors: 23, description: 'Full autonomy. All 15 core + 8 life-critical factors for safety-critical applications.', capabilities: ['Full autonomy', 'Self-governance', 'Life-critical operations'] },
];
---

<BaseLayout title="BASIS Standard" description="Open governance standard for AI agents - 8-tier trust framework with 23 trust factors, tier-gated capabilities, and KYA verification">
  <article class="py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <a href="/projects" class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-white mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Projects
        </a>

        <div class="flex items-start gap-4 mb-6">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-vorion-500/20 to-accent-cyan/20 border border-vorion-500/20 flex items-center justify-center text-3xl">
            📐
          </div>
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">BASIS Standard</h1>
            <div class="flex flex-wrap items-center gap-3">
              <span class="px-3 py-1 text-sm font-medium rounded-full bg-amber-500/20 text-amber-400 border border-amber-500/30">
                v1.0.1 Shipped
              </span>
              <span class="px-3 py-1 text-sm font-medium rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">
                Open Source
              </span>
              <span class="text-sm text-slate-500">Apache-2.0 License</span>
            </div>
          </div>
        </div>

        <p class="text-xl text-slate-400 leading-relaxed">
          Behavioral AI Safety and Integrity Standard — An open specification for AI agent governance,
          defining 8 trust tiers, 23 trust factors, tier-gated capabilities, and the KYA (Know Your Agent) verification framework.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap gap-4 mb-12 p-6 rounded-xl bg-slate-900/50 border border-slate-800">
        <a
          href="https://github.com/vorionsys/basis"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-white transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          View on GitHub
        </a>
        <a
          href="https://basis.vorion.org"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 rounded-lg bg-vorion-500 hover:bg-vorion-600 text-white transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Visit basis.vorion.org
        </a>
      </div>

      <!-- Overview -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-4">Overview</h2>
        <div class="prose prose-invert prose-slate max-w-none">
          <p class="text-slate-400 leading-relaxed mb-4">
            BASIS (Behavioral AI Safety and Integrity Standard) is an open governance specification
            designed to bring trust, accountability, and oversight to autonomous AI systems. It provides
            a framework for evaluating, scoring, and managing AI agent behavior in production environments.
          </p>
          <p class="text-slate-400 leading-relaxed">
            The standard defines an 8-tier trust system (T0-T7) with 23 trust factors (15 core + 8 life-critical),
            tier-gated capability unlocking, a Validation Gate for PASS/REJECT/ESCALATE decisions, and the
            KYA (Know Your Agent) verification framework covering Identity, Authorization, Accountability, and Behavior.
          </p>
        </div>
      </section>

      <!-- Trust Levels -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">8-Tier Trust System (T0-T7)</h2>
        <p class="text-slate-400 mb-6">
          Agents start at T0 (Sandbox) and progress through tiers by demonstrating trust factors.
          Each tier unlocks new capabilities while requiring additional factors to be proven.
        </p>
        <div class="space-y-4">
          {trustLevels.map(tier => (
            <div class="p-6 rounded-xl bg-slate-900/50 border border-slate-800">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-vorion-500/30 to-accent-cyan/30 flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                  T{tier.tier}
                </div>
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-lg font-semibold text-white">{tier.name}</h3>
                    <span class="px-2 py-0.5 text-xs font-mono rounded bg-slate-800 text-slate-400">
                      {tier.score} points
                    </span>
                    <span class="px-2 py-0.5 text-xs font-mono rounded bg-vorion-500/20 text-vorion-400">
                      {tier.factors} factors
                    </span>
                  </div>
                  <p class="text-slate-400 text-sm mb-3">{tier.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {tier.capabilities.map(cap => (
                      <span class="px-2 py-1 text-xs rounded bg-slate-800/50 text-slate-500">
                        {cap}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Key Features -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">Key Features</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-xl bg-slate-900/50 border border-slate-800">
            <h3 class="font-semibold text-white mb-2">23 Trust Factors</h3>
            <p class="text-sm text-slate-400">
              15 core factors (Competence, Reliability, Observability, Transparency, Safety, Accountability,
              Privacy, Security, Alignment, Oversight, Consent, Explainability, Humility, Stewardship, Learning)
              plus 8 life-critical factors for healthcare and safety applications.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-slate-900/50 border border-slate-800">
            <h3 class="font-semibold text-white mb-2">Validation Gate</h3>
            <p class="text-sm text-slate-400">
              Central PASS/REJECT/ESCALATE decision engine. Validates CAR format, verifies agent manifests,
              matches capabilities against trust tiers, and enforces configurable policies in strict or production mode.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-slate-900/50 border border-slate-800">
            <h3 class="font-semibold text-white mb-2">KYA Framework</h3>
            <p class="text-sm text-slate-400">
              Know Your Agent verification with 4 pillars: Identity (DID-based verification),
              Authorization (policy-based access), Accountability (audit chain logging),
              and Behavior (anomaly detection and monitoring).
            </p>
          </div>
          <div class="p-6 rounded-xl bg-slate-900/50 border border-slate-800">
            <h3 class="font-semibold text-white mb-2">Tier-Gated Capabilities</h3>
            <p class="text-sm text-slate-400">
              35 capabilities across 8 categories (Data Access, File Operations, API Access, Code Execution,
              Agent Interaction, Resource Management, System Administration, Governance) progressively unlocked
              from T0 (3 caps) to T7 (all 35).
            </p>
          </div>
        </div>
      </section>

      <!-- Three Layers -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">The Three Layers</h2>
        <p class="text-slate-400 mb-6">
          BASIS governance operates through three interconnected layers that process every AI action:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="https://basis.vorion.org/basis/intent" target="_blank" rel="noopener noreferrer" class="p-6 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-vorion-500/50 transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-vorion-500/20 flex items-center justify-center text-vorion-400 font-mono font-bold mb-3 group-hover:bg-vorion-500/30 transition-colors">1</div>
            <h3 class="font-semibold text-white mb-2">Intent</h3>
            <p class="text-sm text-slate-400">Parse, classify, and risk-score agent intentions before execution.</p>
          </a>
          <a href="https://basis.vorion.org/basis/enforce" target="_blank" rel="noopener noreferrer" class="p-6 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-vorion-500/50 transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-vorion-500/20 flex items-center justify-center text-vorion-400 font-mono font-bold mb-3 group-hover:bg-vorion-500/30 transition-colors">2</div>
            <h3 class="font-semibold text-white mb-2">Enforce</h3>
            <p class="text-sm text-slate-400">Evaluate trust levels and apply policy rules to gate capabilities.</p>
          </a>
          <a href="https://basis.vorion.org/basis/proof" target="_blank" rel="noopener noreferrer" class="p-6 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-vorion-500/50 transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-vorion-500/20 flex items-center justify-center text-vorion-400 font-mono font-bold mb-3 group-hover:bg-vorion-500/30 transition-colors">3</div>
            <h3 class="font-semibold text-white mb-2">Proof</h3>
            <p class="text-sm text-slate-400">Immutable audit trail with hash chains, optional Merkle aggregation, and ZK proofs for privacy-preserving verification.</p>
          </a>
        </div>
      </section>

      <!-- Trust Decay -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6">Stepped Trust Decay</h2>
        <p class="text-slate-400 mb-6">
          Trust scores decay at specific milestones, not continuously. This provides predictable, transparent
          decay behavior with a 182-day half-life. Activity resets the decay clock. Agents in Sandbox (T0)
          must actively earn trust through the boot camp process to progress.
        </p>
        <div class="rounded-xl bg-slate-900/50 border border-slate-800 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-slate-800/50">
              <tr>
                <th class="px-4 py-3 text-left text-slate-300 font-medium">Days Inactive</th>
                <th class="px-4 py-3 text-left text-slate-300 font-medium">Decay Factor</th>
                <th class="px-4 py-3 text-left text-slate-300 font-medium">Score Example</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
              <tr><td class="px-4 py-3 text-slate-400">0-6</td><td class="px-4 py-3 text-emerald-400">100%</td><td class="px-4 py-3 text-slate-500">Grace period</td></tr>
              <tr><td class="px-4 py-3 text-slate-400">7</td><td class="px-4 py-3 text-yellow-400">~93%</td><td class="px-4 py-3 text-slate-500">Early warning</td></tr>
              <tr><td class="px-4 py-3 text-slate-400">14</td><td class="px-4 py-3 text-yellow-400">~87%</td><td class="px-4 py-3 text-slate-500">Two-week checkpoint</td></tr>
              <tr><td class="px-4 py-3 text-slate-400">28</td><td class="px-4 py-3 text-orange-400">~80%</td><td class="px-4 py-3 text-slate-500">One-month threshold</td></tr>
              <tr><td class="px-4 py-3 text-slate-400">56</td><td class="px-4 py-3 text-orange-400">~70%</td><td class="px-4 py-3 text-slate-500">Two-month mark</td></tr>
              <tr><td class="px-4 py-3 text-slate-400">112</td><td class="px-4 py-3 text-red-400">~58%</td><td class="px-4 py-3 text-slate-500">Four-month drop</td></tr>
              <tr><td class="px-4 py-3 text-slate-400 font-medium">182</td><td class="px-4 py-3 text-red-400 font-medium">50%</td><td class="px-4 py-3 text-slate-300 font-medium">Half-life reached</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Implementation -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-4">Implementation</h2>
        <p class="text-slate-400 mb-6">
          The reference implementation is available in the <code class="px-2 py-1 rounded bg-slate-800 text-vorion-400 text-sm">@vorionsys/basis</code> package.
          The runtime trust engine is provided by <code class="px-2 py-1 rounded bg-slate-800 text-vorion-400 text-sm">@vorionsys/atsf-core</code>.
        </p>
        <div class="rounded-xl bg-slate-900 border border-slate-800 overflow-hidden">
          <div class="px-4 py-2 bg-slate-800/50 border-b border-slate-700 flex items-center gap-2">
            <span class="text-sm text-slate-400">TypeScript</span>
          </div>
          <pre class="p-4 text-sm overflow-x-auto"><code class="text-slate-300">import {'{'} TrustTier, TIER_THRESHOLDS, scoreToTier {'}'} from '@vorionsys/basis';
import {'{'} validateAgent {'}'} from '@vorionsys/basis/validation-gate';

// Score maps to tier
const tier = scoreToTier(720); // TrustTier.T4_OPERATIONAL

// Validate an agent manifest
const result = validateAgent({'{'}
  car: 'car:vorion:agent-001:d3:l4:v1.0',
  trustScore: 720,
  capabilities: ['read_data', 'call_api', 'manage_resources'],
{'}'});

console.log(result.decision); // 'PASS' | 'REJECT' | 'ESCALATE'
console.log(result.tier);     // T4_OPERATIONAL
console.log(result.allowed);  // Capabilities permitted at this tier</code></pre>
        </div>
      </section>

      <!-- Related -->
      <section>
        <h2 class="text-2xl font-bold text-white mb-4">Related Projects</h2>
        <div class="flex flex-wrap gap-4">
          <a href="/projects/atsf" class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white transition-colors">
            ATSF Framework
          </a>
          <a href="/projects/cognigate" class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white transition-colors">
            Cognigate Runtime
          </a>
          <a href="/packages#basis" class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white transition-colors">
            @vorionsys/basis
          </a>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
