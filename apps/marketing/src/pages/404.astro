---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <p class="text-7xl font-bold text-white/10 mb-4">404</p>
      <h1 class="text-2xl font-bold text-white mb-3">Page not found</h1>
      <p class="text-white/50 mb-8">The page you're looking for doesn't exist or has been moved.</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
        <a href="https://vorion.org" class="px-5 py-2.5 bg-white/10 hover:bg-white/15 text-white rounded-lg text-sm font-medium transition-colors">
          vorion.org
        </a>
        <a href="https://basis.vorion.org" class="px-5 py-2.5 bg-white/10 hover:bg-white/15 text-white rounded-lg text-sm font-medium transition-colors">
          BASIS Standard
        </a>
        <a href="https://opensource.vorion.org" class="px-5 py-2.5 bg-white/10 hover:bg-white/15 text-white rounded-lg text-sm font-medium transition-colors">
          Open Source
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-xs text-white/30">
        <a href="https://carid.vorion.org" class="hover:text-white/60 transition-colors">CAR ID</a>
        <a href="https://logic.vorion.org" class="hover:text-white/60 transition-colors">Logic</a>
        <a href="https://trust.vorion.org" class="hover:text-white/60 transition-colors">Trust</a>
        <a href="https://verify.vorion.org" class="hover:text-white/60 transition-colors">Verify</a>
        <a href="https://feedback.vorion.org" class="hover:text-white/60 transition-colors">Feedback</a>
        <a href="https://opensource.vorion.org" class="hover:text-white/60 transition-colors">Open Source</a>
      </div>
    </div>
  </div>
</BaseLayout>
