---
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  description: string;
  status: 'success' | 'failure' | 'pending' | 'unknown';
  runUrl: string | null;
  updatedAt: string | null;
  durationSeconds: number | null;
}

const { name, description, status, runUrl, updatedAt, durationSeconds } = Astro.props;

const borderColorMap: Record<string, string> = {
  success: 'border-l-emerald-500',
  failure: 'border-l-red-500',
  pending: 'border-l-amber-500',
  unknown: 'border-l-slate-500',
};

function formatRelativeTime(dateStr: string | null): string {
  if (!dateStr) return 'Never';
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffSec = Math.floor(diffMs / 1000);
  const diffMin = Math.floor(diffSec / 60);
  const diffHour = Math.floor(diffMin / 60);
  const diffDay = Math.floor(diffHour / 24);

  if (diffSec < 60) return 'just now';
  if (diffMin < 60) return `${diffMin}m ago`;
  if (diffHour < 24) return `${diffHour}h ago`;
  if (diffDay < 30) return `${diffDay}d ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function formatDuration(seconds: number | null): string {
  if (seconds === null) return '--';
  if (seconds < 60) return `${seconds}s`;
  const min = Math.floor(seconds / 60);
  const sec = seconds % 60;
  return sec > 0 ? `${min}m ${sec}s` : `${min}m`;
}

const relativeTime = formatRelativeTime(updatedAt);
const duration = formatDuration(durationSeconds);
const borderColor = borderColorMap[status] || 'border-l-slate-500';
---

<div
  class:list={[
    'bg-slate-900/50 border border-slate-800 rounded-xl p-4 border-l-4 transition-all duration-300 hover:bg-slate-900',
    borderColor,
  ]}
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <div class="min-w-0 flex-1">
      <h4 class="font-semibold text-white text-sm truncate">{name}</h4>
      <p class="text-sm text-slate-400 mt-0.5 line-clamp-2">{description}</p>
    </div>
    <StatusBadge status={status} size="md" />
  </div>

  <div class="flex items-center gap-4 mt-3 text-xs text-slate-500">
    <!-- Last run -->
    <span class="inline-flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {relativeTime}
    </span>

    <!-- Duration -->
    <span class="inline-flex items-center gap-1">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      {duration}
    </span>

    <!-- GitHub Actions link -->
    {runUrl && (
      <a
        href={runUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-vorion-400 hover:text-vorion-300 transition-colors ml-auto"
      >
        <span>View run</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
  </div>
</div>
