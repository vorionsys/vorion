---
interface Props {
  daysRemaining: number | null;
}

const { daysRemaining } = Astro.props;

function getBadgeConfig(days: number | null): { color: string; bgColor: string; text: string; pulse: boolean } {
  if (days === null) {
    return { color: 'text-slate-400', bgColor: 'bg-slate-800', text: 'N/A', pulse: false };
  }
  if (days < 7) {
    return { color: 'text-red-400', bgColor: 'bg-red-500/10 border border-red-500/30', text: `${days}d`, pulse: true };
  }
  if (days < 30) {
    return { color: 'text-red-400', bgColor: 'bg-red-500/10 border border-red-500/30', text: `${days}d`, pulse: false };
  }
  if (days <= 60) {
    return { color: 'text-amber-400', bgColor: 'bg-amber-500/10 border border-amber-500/30', text: `${days}d`, pulse: false };
  }
  return { color: 'text-emerald-400', bgColor: 'bg-emerald-500/10 border border-emerald-500/30', text: `${days}d`, pulse: false };
}

const config = getBadgeConfig(daysRemaining);
---

<span
  class:list={[
    'inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-mono',
    config.bgColor,
    config.color,
    config.pulse && 'animate-pulse',
  ]}
  title={daysRemaining !== null ? `SSL certificate expires in ${daysRemaining} days` : 'SSL status unknown'}
>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
  </svg>
  {config.text}
</span>
