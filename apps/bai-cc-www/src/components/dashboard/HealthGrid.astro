---
interface HealthItem {
  label: string;
  status: 'up' | 'down' | 'degraded';
  href?: string;
  tooltip?: string;
}

interface Props {
  items: HealthItem[];
}

const { items } = Astro.props;

const colorMap: Record<string, string> = {
  up: 'bg-emerald-500 hover:bg-emerald-400',
  down: 'bg-red-500 hover:bg-red-400',
  degraded: 'bg-amber-500 hover:bg-amber-400',
};
---

<div class="flex flex-wrap gap-1.5">
  {items.map((item) => {
    const Tag = item.href ? 'a' : 'div';
    const linkProps = item.href ? { href: item.href } : {};
    const tooltipText = item.tooltip || item.label;

    return (
      <Tag
        {...linkProps}
        class:list={[
          'w-8 h-8 rounded transition-all duration-200',
          colorMap[item.status] || 'bg-slate-600',
          item.href && 'cursor-pointer hover:scale-110',
        ]}
        title={tooltipText}
        aria-label={`${item.label}: ${item.status}`}
      />
    );
  })}
</div>
